# ================================================================
# media-compliance-ai — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is already in .gitignore.
# ================================================================

# --- AZURE OPENAI ---
# Portal → Azure AI Foundry → Your deployment → Keys & Endpoint
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"
AZURE_OPENAI_ENDPOINT="https://<your-resource>.cognitiveservices.azure.com/"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"
AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-4o"
AZURE_OPENAI_EMBEDDING_DEPLOYMENT="text-embedding-3-small"

# --- AZURE AI SEARCH (Knowledge Base / Vector Store) ---
# Portal → Azure AI Search → Your resource → Keys & URL
AZURE_SEARCH_ENDPOINT="https://<your-resource>.search.windows.net"
AZURE_SEARCH_API_KEY="your-azure-search-api-key"
AZURE_SEARCH_INDEX_NAME="compliance-rules"

# --- AZURE VIDEO INDEXER ---
# Portal → Video Indexer resource → Overview
AZURE_VI_NAME="your-video-indexer-resource-name"
AZURE_VI_LOCATION="eastus"
AZURE_VI_ACCOUNT_ID="your-video-indexer-account-guid"
AZURE_SUBSCRIPTION_ID="your-azure-subscription-id"
AZURE_RESOURCE_GROUP="your-resource-group-name"

# --- AZURE STORAGE (Temp video upload) ---
# Portal → Storage Account → Access keys
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net"

# --- AZURE MONITOR (Telemetry / App Insights) ---
# Portal → Application Insights → Overview → Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING="InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/"

# --- LANGSMITH (LangGraph Tracing & Debugging) ---
# smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your-langsmith-api-key"
LANGCHAIN_PROJECT="media-compliance-ai"
